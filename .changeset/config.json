{
  "$schema": "https://unpkg.com/@changesets/config@3.1.3/schema.json",
  "commit": false,
  "fixed": [],
  "linked": [],
  "access": "restricted",
  "baseBranch": "main",
  "updateInternalDependencies": "patch",
  "ignore": [
    "@macrostrat/cross-section-utils",
    "@macrostrat/web-components-bundler",
    "@macrostrat/column-creator"
  ],
  "changelog": [
    "changesets-format-with-issue-links",
    {
      "repoBaseUrl": "https://github.com/UW-Macrostrat/web-components",
      "issueTemplate": " ([#$issue]($repoBaseUrl/pull/$issue))",
      "commitTemplate": " [$abbrevHash]($repoBaseUrl/commit/$hash)"
    }
  ]
}
